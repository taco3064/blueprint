{
  "name": "@kekkai/blueprint",
  "version": "1.0.3",
  "description": "Architecture as Code — one Blueprint compiles into docs, agent contracts, lint, and CI for Vue & React projects.",
  "type": "module",
  "license": "MIT",
  "author": "taco3064 <tabacotaco@gmail.com>",
  "homepage": "https://github.com/taco3064/blueprint#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taco3064/blueprint.git"
  },
  "bugs": {
    "url": "https://github.com/taco3064/blueprint/issues"
  },
  "keywords": [
    "architecture",
    "architecture-as-code",
    "eslint",
    "vue",
    "react",
    "scaffolding",
    "dependency-flow",
    "code-quality",
    "coding-agent"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "blueprint": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && rolldown -c rolldown.config.ts && tsc -b tsconfig.types.json --force",
    "changeset": "changeset",
    "commit": "cz",
    "lint": "eslint .",
    "prepare": "husky",
    "test": "vitest run --coverage",
    "tsc": "tsc -p tsconfig.lib.json && tsc -p tsconfig.test.json",
    "docs:api": "typedoc && rm -rf docs/zh-TW/api && cp -R docs/api docs/zh-TW/api",
    "docs:dev": "npm run docs:api && vitepress dev docs",
    "docs:build": "npm run docs:api && vitepress build docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.2.7",
    "rolldown": "^1.0.0-beta.57",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.16"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ]
  }
}
